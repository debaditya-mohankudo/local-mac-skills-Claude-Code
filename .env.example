# iMessage Configuration
# Copy this file to .env and update with your contact information
# .env is in .gitignore and should not be committed

# Default phone number for iMessage command executor (imessage_command_executor.sh)
# Can be a phone number in E.164 format or email address
# Usage: bash imessage_command_executor.sh [CONTACT]
# Example: bash imessage_command_executor.sh +91XXXXXXXXXX
# Example: bash imessage_command_executor.sh user@example.com
# Or use this as default if no argument is provided:
PHONE_NUMBER=+91XXXXXXXXXX

# Phone number for iMessage checking (imessage_check.sh)
# Usage: imessage_check.sh [MINUTES] [PHONE_NUMBER]
# Example: imessage_check.sh 120 (uses phone number below)
# Example: imessage_check.sh 120 +91XXXXXXXXXX (overrides with custom number)
IMESSAGE_PHONE_NUMBER=+91XXXXXXXXXX

# Allowed phone numbers for sending messages (comma-separated, optional)
# If set, messages can only be sent to these numbers
# If not set or empty, messages can be sent to any recipient
# Example: ALLOWED_PHONE_NUMBERS=+91XXXXXXXXXX,user@example.com
ALLOWED_PHONE_NUMBERS=
